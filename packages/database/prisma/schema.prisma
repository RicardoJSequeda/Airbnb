generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["users", "listings", "bookings", "payments", "platform"]
}

enum UserRole {
  GUEST
  HOST
  ADMIN
  SUPER_ADMIN

  @@schema("users")
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE

  @@schema("users")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE

  @@schema("users")
}

model PropertyAmenity {
  id          String   @id @default(uuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenityName String

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([amenityName])
  @@map("property_amenities")
  @@schema("listings")
}

model PropertyImage {
  id           String   @id @default(uuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  imageUrl     String
  displayOrder Int      @default(0)
  isPrimary    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([propertyId, displayOrder])
  @@index([propertyId])
  @@map("property_images")
  @@schema("listings")
}

model ExperienceInclude {
  id           String     @id @default(uuid())
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  itemText     String

  createdAt DateTime @default(now())

  @@index([experienceId])
  @@map("experience_includes")
  @@schema("listings")
}

model ExperienceLanguage {
  id           String     @id @default(uuid())
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  languageCode String

  createdAt DateTime @default(now())

  @@index([experienceId])
  @@map("experience_languages")
  @@schema("listings")
}

model ExperienceImage {
  id           String     @id @default(uuid())
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  imageUrl     String
  displayOrder Int        @default(0)
  isCover      Boolean    @default(false)

  createdAt DateTime @default(now())

  @@unique([experienceId, displayOrder])
  @@index([experienceId])
  @@map("experience_images")
  @@schema("listings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
  REFUNDED

  @@schema("bookings")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED

  @@schema("payments")
}

// ==================== MULTI-TENANT SCHEMA ====================
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  subscriptions      Subscription[]
  properties         Property[]
  bookings           Booking[]
  payments           Payment[]
  experiences        Experience[]
  experienceBookings ExperienceBooking[]
  experiencePayments ExperiencePayment[]

  @@map("organizations")
  @@schema("users")
}

model Subscription {
  id               String             @id @default(uuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  stripeCustomerId String?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId])
  @@map("subscriptions")
  @@schema("users")
}

// ==================== AUTH SCHEMA ====================
model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String? // Opcional para usuarios Supabase Auth
  name               String
  avatar             String?
  occupation         String? // Tagline / profesión del host (ej: "Guías culturales en Gran Colombia Tours")
  bio                String? // Biografía del host
  registrationNumber String? // RNT - Registro Nacional de Turismo (Colombia)
  role               UserRole      @default(GUEST)
  authProvider       String        @default("local") // "supabase" | "local"
  supabaseId         String?       @unique // auth.users.id cuando authProvider=supabase
  organizationId     String? // Nullable solo para SUPER_ADMIN
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  properties         Property[]          @relation("HostProperties")
  bookings           Booking[]           @relation("GuestBookings")
  reviews            Review[]            @relation("GuestReviews")
  favorites          Favorite[]
  experiences        Experience[]        @relation("HostExperiences")
  experienceBookings ExperienceBooking[] @relation("GuestExperienceBookings")
  experienceReviews  ExperienceReview[]  @relation("GuestExperienceReviews")

  @@index([supabaseId])
  @@index([organizationId])
  @@map("users")
  @@schema("users")
}

// ==================== PROPERTY SCHEMA ====================
model Property {
  id           String  @id @default(uuid())
  title        String
  description  String
  price        Decimal @db.Decimal(10, 2)
  currency     String  @default("USD")
  maxGuests    Int
  bedrooms     Int
  bathrooms    Int
  propertyType String
  status       String  @default("DRAFT")

  address   String
  city      String
  state     String?
  country   String
  zipCode   String?
  latitude  Float
  longitude Float

  hostId         String
  host           User         @relation("HostProperties", fields: [hostId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  amenities      String
  images         String

  propertyAmenities PropertyAmenity[]
  propertyImages    PropertyImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@index([hostId])
  @@index([organizationId])
  @@index([city, country])
  @@index([propertyType])
  @@map("properties")
  @@schema("listings")
}

// ==================== BOOKING SCHEMA ====================
model Booking {
  id             String        @id @default(uuid())
  propertyId     String
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestId        String
  guest          User          @relation("GuestBookings", fields: [guestId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId       String        @default("default")
  regionId       String        @default("global")
  checkIn        DateTime
  checkOut       DateTime
  guests         Int
  totalPrice     Decimal       @db.Decimal(10, 2)
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payment Payment?
  review  Review?

  @@index([propertyId])
  @@index([guestId])
  @@index([organizationId])
  @@index([status])
  @@index([propertyId, checkIn, checkOut])
  @@index([checkIn, checkOut])
  @@map("bookings")
  @@schema("bookings")
}

// ==================== PAYMENT SCHEMA ====================
model Payment {
  id                    String        @id @default(uuid())
  bookingId             String        @unique
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId              String        @default("default")
  regionId              String        @default("global")
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  platformFeeAmount Decimal? @db.Decimal(10, 2)
  hostNetAmount     Decimal? @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([organizationId])
  @@index([tenantId, regionId])
  @@map("payments")
  @@schema("payments")
}

// ==================== REVIEW SCHEMA ====================
model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestId    String
  guest      User     @relation("GuestReviews", fields: [guestId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
  @@index([guestId])
  @@map("reviews")
  @@schema("listings")
}

// ==================== LOCATIONS SCHEMA ====================
model Department {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  country      String   @default("CO")
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cities City[]

  @@map("departments")
  @@schema("listings")
}

model City {
  id                    String     @id @default(uuid())
  name                  String
  slug                  String
  departmentId          String
  department            Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  suggestionDescription String?
  latitude              Float?
  longitude             Float?
  searchCount           Int        @default(0)
  displayOrder          Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  places             Place[]
  locationSearchLogs LocationSearchLog[]

  @@unique([slug, departmentId])
  @@index([departmentId])
  @@index([slug])
  @@map("cities")
  @@schema("listings")
}

// ==================== OUTBOX EVENTS ====================
model OutboxEvent {
  id             String    @id @default(uuid())
  eventId        String    @unique @default(uuid())
  aggregateId    String
  type           String
  version        String    @default("v1")
  payload        Json
  correlationId  String?
  tenantId       String    @default("default")
  regionId       String    @default("global")
  retryCount     Int       @default(0)
  nextRetryAt    DateTime?
  lastError      String?
  deadLetteredAt DateTime?
  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  @@index([aggregateId])
  @@index([type])
  @@index([processedAt, nextRetryAt])
  @@index([tenantId, regionId, processedAt])
  @@index([deadLetteredAt])
  @@map("outbox_events")
  @@schema("platform")
}

model OutboxDeadLetter {
  id            String   @id @default(uuid())
  outboxEventId String
  aggregateId   String
  type          String
  version       String
  payload       Json
  errorMessage  String
  failedAt      DateTime @default(now())

  @@index([outboxEventId])
  @@index([failedAt])
  @@map("outbox_dead_letter")
  @@schema("platform")
}

model IdempotencyRecord {
  id             String   @id @default(uuid())
  scopeKey       String   @unique
  actorId        String
  operation      String
  tenantId       String   @default("default")
  regionId       String   @default("global")
  method         String
  path           String
  idempotencyKey String
  payloadHash    String
  responseCode   Int?
  responseBody   Json?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([idempotencyKey, actorId, operation])
  @@index([expiresAt])
  @@index([method, path])
  @@index([tenantId, regionId, expiresAt])
  @@map("idempotency_records")
  @@schema("platform")
}

model BookingSummary {
  id             String   @id @default(uuid())
  bookingId      String   @unique
  propertyId     String
  guestId        String
  hostId         String
  organizationId String
  tenantId       String   @default("default")
  regionId       String   @default("global")
  status         String
  paymentStatus  String?
  totalPrice     Decimal  @db.Decimal(10, 2)
  checkIn        DateTime
  checkOut       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([guestId, createdAt])
  @@index([hostId, createdAt])
  @@index([tenantId, regionId, createdAt])
  @@map("booking_summaries")
  @@schema("bookings")
}

model PaymentSummary {
  id                    String    @id @default(uuid())
  paymentId             String    @unique
  bookingId             String    @unique
  organizationId        String
  tenantId              String    @default("default")
  regionId              String    @default("global")
  status                String
  amount                Decimal   @db.Decimal(10, 2)
  currency              String
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([organizationId, createdAt])
  @@index([tenantId, regionId, createdAt])
  @@map("payment_summaries")
  @@schema("payments")
}

model ConsumedEvent {
  id            String   @id @default(uuid())
  consumerGroup String
  eventId       String
  topic         String
  processedAt   DateTime @default(now())

  @@unique([consumerGroup, eventId])
  @@index([topic, processedAt])
  @@map("consumed_events")
  @@schema("platform")
}

model Place {
  id                    String   @id @default(uuid())
  name                  String
  type                  String
  cityId                String
  city                  City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  suggestionDescription String?
  displayOrder          Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([cityId])
  @@map("places")
  @@schema("listings")
}

model LocationSearchLog {
  id        String   @id @default(uuid())
  cityId    String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([cityId])
  @@map("location_search_logs")
  @@schema("listings")
}

model Experience {
  id                  String  @id @default(uuid())
  title               String
  description         String
  pricePerParticipant Decimal @db.Decimal(10, 2)
  currency            String  @default("USD")
  maxParticipants     Int
  duration            Int // Duración en minutos
  category            String // "tour", "workshop", "tasting", "adventure", etc.
  status              String  @default("DRAFT")

  address   String
  city      String
  state     String?
  country   String
  zipCode   String?
  latitude  Float
  longitude Float

  hostId         String
  host           User         @relation("HostExperiences", fields: [hostId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  includes       String // JSON array: ["Guía local", "Entradas", "Transporte"]
  excludes       String? // JSON array: ["Comida", "Propinas"]
  images         String // JSON array de URLs
  meetingPoint   String? // Punto de encuentro
  languages      String? // JSON array: ["es", "en"]
  ageRestriction String? // "18+", "All ages", etc.

  experienceIncludes  ExperienceInclude[]
  experienceLanguages ExperienceLanguage[]
  experienceImages    ExperienceImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings       ExperienceBooking[]
  reviews        ExperienceReview[]
  availableSlots ExperienceSlot[]

  @@index([hostId])
  @@index([organizationId])
  @@index([city, country])
  @@index([category])
  @@index([status])
  @@map("experiences")
  @@schema("listings")
}

model ExperienceSlot {
  id           String     @id @default(uuid())
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  date           DateTime // Fecha específica
  startTime      String // Hora de inicio (ej: "09:00", "21:00")
  endTime        String? // Hora de fin (opcional)
  availableSpots Int // Espacios disponibles
  isRecurring    Boolean  @default(false) // Si se repite semanalmente
  dayOfWeek      Int? // 0=Domingo, 1=Lunes... (solo si isRecurring)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([experienceId])
  @@index([date])
  @@index([dayOfWeek])
  @@map("experience_slots")
  @@schema("listings")
}

model ExperienceBooking {
  id             String       @id @default(uuid())
  experienceId   String
  experience     Experience   @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  guestId        String
  guest          User         @relation("GuestExperienceBookings", fields: [guestId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  date         DateTime // Fecha y hora de la experiencia
  participants Int // Número de participantes
  totalPrice   Decimal       @db.Decimal(10, 2)
  status       BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment ExperiencePayment?
  review  ExperienceReview?

  @@index([experienceId])
  @@index([guestId])
  @@index([organizationId])
  @@index([status])
  @@index([date])
  @@map("experience_bookings")
  @@schema("bookings")
}

model ExperiencePayment {
  id                    String        @id @default(uuid())
  bookingId             String        @unique
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId              String        @default("default")
  regionId              String        @default("global")
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  platformFeeAmount Decimal? @db.Decimal(10, 2)
  hostNetAmount     Decimal? @db.Decimal(10, 2)

  booking ExperienceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([organizationId])
  @@map("experience_payments")
  @@schema("payments")
}

model ExperienceReview {
  id           String            @id @default(uuid())
  bookingId    String            @unique
  booking      ExperienceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  experienceId String
  experience   Experience        @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  guestId      String
  guest        User              @relation("GuestExperienceReviews", fields: [guestId], references: [id], onDelete: Cascade)
  rating       Int
  comment      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([experienceId])
  @@index([guestId])
  @@map("experience_reviews")
  @@schema("listings")
}


model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("favorites")
  @@schema("listings")
}
